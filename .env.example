# Talking Tío — configuration template.
# `make setup` copies this to .env if .env doesn't exist.
# Edit .env (not this file) with your real values — .env is gitignored.

LOG_LEVEL=info

# ─── LLM provider ───────────────────────────────────────────
# Pick one: "ollama" (local, free, needs Ollama running) or "gemini" (cloud).
LLM_PROVIDER=ollama

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Gemini (used when LLM_PROVIDER=gemini) — get a free key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=00000000000000000000000000000000000
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# ─── Speech ─────────────────────────────────────────────────
WHISPER_MODEL_PATH=./stt/models/ggml-small.bin
WHISPER_LANGUAGE=en

# Empty TTS_VOICE = macOS system default (set via System Settings →
# Accessibility → Spoken Content → Manage Voices). Only path to a Siri voice.
TTS_BACKEND=say
TTS_VOICE=

# ─── Vision sidecar ─────────────────────────────────────────
VISION_CONTEXT_PATH=./vision/visual_context.json

# ─── Persistence ────────────────────────────────────────────
POSTGRES_URI=postgres://tio:tio@localhost:5433/tio?sslmode=disable

# ─── Agent tuning ───────────────────────────────────────────
AGENT_CONTEXT_MAX_MESSAGES=8
AGENT_MAX_ITERATIONS=4
SPONTANEOUS_INTERVAL_SECONDS=35
VOICE_COOLDOWN_SECONDS=300
